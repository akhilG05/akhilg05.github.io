---
import { profile } from '../data/profile';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <p>Copyright {year} {profile.name}</p>
  <div class="footer-social" aria-label="Social links">
    <a class="social-link" href={profile.github} target="_blank" rel="noreferrer" aria-label="GitHub">
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M12 2A10 10 0 0 0 8.84 21.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.19-3.37-1.19-.45-1.17-1.11-1.48-1.11-1.48-.91-.62.07-.61.07-.61 1 .07 1.53 1.04 1.53 1.04.9 1.53 2.35 1.09 2.92.83.09-.65.35-1.09.64-1.34-2.22-.25-4.56-1.13-4.56-5.02 0-1.11.39-2.01 1.03-2.72-.1-.25-.45-1.28.1-2.67 0 0 .85-.28 2.78 1.04A9.57 9.57 0 0 1 12 6.8c.85 0 1.71.12 2.51.35 1.93-1.32 2.78-1.04 2.78-1.04.55 1.39.2 2.42.1 2.67.64.71 1.03 1.61 1.03 2.72 0 3.9-2.35 4.77-4.58 5.02.36.32.68.93.68 1.88v2.79c0 .27.18.58.69.48A10 10 0 0 0 12 2Z" fill="currentColor"/>
      </svg>
    </a>
    <a class="social-link" href={profile.linkedin} target="_blank" rel="noreferrer" aria-label="LinkedIn">
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M6.94 8.5v9.56H3.76V8.5h3.18ZM5.35 3.4a1.84 1.84 0 1 1 0 3.68 1.84 1.84 0 0 1 0-3.68ZM20.24 12.57v5.49h-3.17v-5.12c0-1.22-.44-2.05-1.54-2.05-.84 0-1.34.57-1.56 1.12-.08.19-.1.46-.1.73v5.32h-3.18s.04-8.63 0-9.56h3.18v1.35c.42-.66 1.18-1.6 2.88-1.6 2.11 0 3.69 1.37 3.69 4.32Z" fill="currentColor"/>
      </svg>
    </a>
    <a
      class="social-link"
      href={`https://mail.google.com/mail/?view=cm&fs=1&to=${encodeURIComponent(profile.email)}`}
      target="_blank"
      rel="noreferrer"
      aria-label="Gmail"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M3 6.75A1.75 1.75 0 0 1 4.75 5h14.5A1.75 1.75 0 0 1 21 6.75v10.5A1.75 1.75 0 0 1 19.25 19H4.75A1.75 1.75 0 0 1 3 17.25V6.75Zm1.75-.25a.25.25 0 0 0-.25.25v.38L12 12.1l7.5-4.97v-.38a.25.25 0 0 0-.25-.25H4.75Zm14.75 2.44L12.41 13.7a.75.75 0 0 1-.82 0L4.5 8.94v8.31c0 .14.11.25.25.25h14.5c.14 0 .25-.11.25-.25V8.94Z" fill="currentColor"/>
      </svg>
    </a>
  </div>
</footer>