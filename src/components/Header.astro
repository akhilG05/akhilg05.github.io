---
import { profile } from '../data/profile';

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
  { href: '/publications', label: 'Publications' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="site-header">
  <a class="brand" href="/" aria-label={`${profile.shortName} home`}>
    <span class="brand-mark">AG</span>
    <span>{profile.shortName}</span>
  </a>
  <nav class="site-nav" aria-label="Main navigation">
    {
      navItems.map((item) => {
        const itemPath = item.href.replace(/\/$/, '') || '/';
        const isActive = itemPath === '/' ? currentPath === '/' : currentPath.startsWith(itemPath);
        return (
          <a href={item.href} aria-current={isActive ? 'page' : undefined}>
            {item.label}
          </a>
        );
      })
    }
  </nav>
</header>