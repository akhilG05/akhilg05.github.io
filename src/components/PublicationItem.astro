---
import type { CollectionEntry } from 'astro:content';

interface Props {
  publication: CollectionEntry<'publications'>;
  compact?: boolean;
}

const { publication, compact = false } = Astro.props;
const { data } = publication;
const shouldOpenInNewTab = (href: string) => href.startsWith('http') || href.toLowerCase().endsWith('.pdf');
---

<article class={compact ? 'publication-item publication-item--compact' : 'publication-item'}>
  <p class="meta-line">{data.type} | {data.date}</p>
  <h3>{data.title}</h3>
  <p>{data.authors}</p>
  <p class="muted publication-venue">
    <span>{data.venue}</span>
    {data.location && <span class="publication-location">{data.location}</span>}
  </p>
  {
    (data.status || data.identifier) && (
      <div class="publication-details">
        {data.status && <p class="status-line">{data.status}</p>}
        {data.identifier && <p class="identifier-line">{data.identifier}</p>}
      </div>
    )
  }
  {
    !compact && data.links.length > 0 && (
      <div class="inline-links">
        {data.links.map((link) => {
          const openInNewTab = shouldOpenInNewTab(link.href);

          return (
            <a href={link.href} target={openInNewTab ? '_blank' : undefined} rel={openInNewTab ? 'noreferrer' : undefined}>
              {link.label}
            </a>
          );
        })}
      </div>
    )
  }
</article>