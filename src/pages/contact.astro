---
import BaseLayout from '../layouts/BaseLayout.astro';
import { profile } from '../data/profile';
---

<BaseLayout title="Contact" description={`Contact ${profile.shortName} for robotics, embedded systems, medical technology software, and research collaborations.`}>
  <main id="main" class="page-main">
    <section class="section-wrap page-hero contact-hero reveal">
      <p class="section-kicker">Contact</p>
      <h1>For robotics, embedded systems, medical technology software, or engineering conversations.</h1>
      <p>{profile.location}</p>
      <div class="contact-actions">
        <a
          class="contact-social-link"
          href={`https://mail.google.com/mail/?view=cm&fs=1&to=${encodeURIComponent(profile.email)}`}
          target="_blank"
          rel="noreferrer"
          aria-label="Gmail"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M3 6.75A1.75 1.75 0 0 1 4.75 5h14.5A1.75 1.75 0 0 1 21 6.75v10.5A1.75 1.75 0 0 1 19.25 19H4.75A1.75 1.75 0 0 1 3 17.25V6.75Zm1.75-.25a.25.25 0 0 0-.25.25v.38L12 12.1l7.5-4.97v-.38a.25.25 0 0 0-.25-.25H4.75Zm14.75 2.44L12.41 13.7a.75.75 0 0 1-.82 0L4.5 8.94v8.31c0 .14.11.25.25.25h14.5c.14 0 .25-.11.25-.25V8.94Z" fill="currentColor"/>
          </svg>
          <span>Email</span>
        </a>
        <a class="contact-social-link" href={profile.linkedin} target="_blank" rel="noreferrer" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M6.94 8.5v9.56H3.76V8.5h3.18ZM5.35 3.4a1.84 1.84 0 1 1 0 3.68 1.84 1.84 0 0 1 0-3.68ZM20.24 12.57v5.49h-3.17v-5.12c0-1.22-.44-2.05-1.54-2.05-.84 0-1.34.57-1.56 1.12-.08.19-.1.46-.1.73v5.32h-3.18s.04-8.63 0-9.56h3.18v1.35c.42-.66 1.18-1.6 2.88-1.6 2.11 0 3.69 1.37 3.69 4.32Z" fill="currentColor"/>
          </svg>
          <span>LinkedIn</span>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>