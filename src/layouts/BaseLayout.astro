---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { profile } from '../data/profile';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = profile.summary } = Astro.props;
const site = Astro.site ?? new URL('https://akhileshgonabal.com');
const pageTitle = title === 'Home' ? `${profile.shortName} | ${profile.role}` : `${title} | ${profile.shortName}`;
const canonical = new URL(Astro.url.pathname, site);
const ogImage = new URL('/img/profile.png', site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={profile.name} />
    <meta name="keywords" content="robotics, embedded systems, automation, cyber-physical systems, ROS, inspection robotics" />
    <link rel="canonical" href={canonical.toString()} />
    <link rel="icon" href="/img/favicon.ico" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.toString()} />
    <meta property="og:image" content={ogImage.toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="site-shell">
      <Header />
      <slot />
      <Footer />
    </div>
  </body>
</html>