---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { profile } from '../data/profile';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = profile.summary } = Astro.props;
const site = Astro.site ?? new URL('https://akhileshgonabal.com');
const pageTitle = title === 'Home' ? `${profile.shortName} | ${profile.role}` : `${title} | ${profile.shortName}`;
const canonical = new URL(Astro.url.pathname, site);
const ogImage = new URL('/img/profile.png', site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#f4f7f5" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#111512" media="(prefers-color-scheme: dark)" />
    <title>{pageTitle}</title>
    <script is:inline>
      (() => {
        try {
          const theme = localStorage.getItem('theme-preference');
          if (theme === 'light' || theme === 'dark') {
            document.documentElement.dataset.theme = theme;
          }
        } catch {
          // Keep the system preference if storage is unavailable.
        }
      })();
    </script>
    <meta name="description" content={description} />
    <meta name="author" content={profile.name} />
    <meta name="keywords" content="robotics, embedded systems, cyber-physical systems, automation, medical technology software, C++, Qt QML, NVIDIA Jetson, computer vision" />
    <link rel="canonical" href={canonical.toString()} />
    <link rel="icon" type="image/svg+xml" href="/img/favicon-light.svg?v=4" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/svg+xml" href="/img/favicon-dark.svg?v=4" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/svg+xml" href="/img/favicon.svg?v=4" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.toString()} />
    <meta property="og:image" content={ogImage.toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="site-shell">
      <Header />
      <slot />
      <Footer />
    </div>
  </body>
</html>